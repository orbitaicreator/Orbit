{
  "name": "yoda",
  "version": "1.0.18",
  "description": "Yoda AI Assistant",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "dist": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.yoda.assistant",
    "productName": "Yoda",
    "copyright": "Copyright 2025 Kristian",
    "directories": {
      "output": "installer",
      "buildResources": "assets"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Yoda",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "include": "installer.nsh"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json",
      "!node_modules/**/*.{map,md,ts,flow,txt}",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS}"
    ],
    "extraResources": [
      {
        "from": "yoda_mic.py",
        "to": "yoda_mic.py"
      },
      {
        "from": "yoda_tts.py",
        "to": "yoda_tts.py"
      },
      {
        "from": "yoda_mouse.py",
        "to": "yoda_mouse.py"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "yodaaicreator",
      "repo": "yoda",
      "releaseType": "release"
    },
    "compression": "maximum"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "electron-updater": "^6.3.0",
    "electron-log": "^5.1.0"
  },
  "devDependencies": {
    "electron": "42.0.1",
    "electron-builder": "^26.8.1"
  },
  "author": "Kristian"
}